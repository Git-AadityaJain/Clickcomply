# Production env for docker-compose.prod.yml. Copy to .env and edit.
#
#   cp .env.prod.example .env
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build

# PostgreSQL credentials (used by the db service and the backend DATABASE_URL)
POSTGRES_USER=clickcomply
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=clickcomply

# Auth (Phase 2). JWT_SECRET is REQUIRED in prod — generate a long random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
REQUIRE_AUTH=true
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Comma-separated allowed browser origins for CORS
CORS_ORIGINS=http://localhost:3000
