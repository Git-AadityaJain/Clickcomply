# ClickComply backend: copy to backend/.env (optional; defaults work with Ollama)

# AI provider: ollama (free, local) | openai | gemini
AI_PROVIDER=ollama

# Ollama: no API key required (install from https://ollama.com)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=300

# Pull models once before first analysis:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text

# Optional paid cloud providers (set AI_PROVIDER accordingly)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Optional tuning
DEBUG=true
AI_MAX_DOCUMENT_CHARS=12000
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
RAG_TOP_K_DPDP=3
RAG_TOP_K_DOCUMENT=5

# --- Database (Phase 2) ---
# Local dev defaults to SQLite. For PostgreSQL use the asyncpg driver:
#   DATABASE_URL=postgresql+asyncpg://clickcomply:clickcomply@localhost:5432/clickcomply
# PostgreSQL schema is managed by Alembic: `alembic upgrade head`.
# DATABASE_URL=

# --- Auth (Phase 2) ---
# REQUIRE_AUTH=false keeps the open local workflow; set true to force login.
REQUIRE_AUTH=false
# JWT_SECRET is REQUIRED when REQUIRE_AUTH=true. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Comma-separated allowed browser origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
